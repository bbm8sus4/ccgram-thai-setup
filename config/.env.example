# ===== ccgram config (~/.ccgram/.env) — TEMPLATE =====
# คัดลอกเป็น ~/.ccgram/.env แล้วเติมค่าจริง  (chmod 600 ~/.ccgram/.env)
# โหลดลำดับ: .env ใน cwd > ~/.ccgram/.env

# ---- จำเป็น ----
TELEGRAM_BOT_TOKEN=            # จาก @BotFather (/newbot) — เก็บเป็นความลับ
ALLOWED_USERS=                # numeric user-id ของคุณ (จาก @userinfobot) — whitelist เฉพาะคุณ
CCGRAM_GROUP_ID=              # supergroup id (-100...) ที่เปิด Topics + บอทเป็น admin

# ---- ค่าตั้งต้น ----
CCGRAM_PROVIDER=claude        # claude | codex | gemini | pi | shell
TMUX_SESSION_NAME=ccgram
CCGRAM_LOG_LEVEL=info         # info | debug  (ต้องแพตช์ ccgram-tune.py ก่อนคีย์นี้ถึงจะทำงาน)

# ---- tuning (จากชุดแพตช์นี้) ----
AUTOCLOSE_DONE_MINUTES=0      # 0 = ไม่ลบ topic ที่เสร็จแล้วทิ้ง (กันงานหาย)
AUTOCLOSE_DEAD_MINUTES=0      # 0 = ไม่ลบ topic ที่ตายแล้วทิ้ง
CCGRAM_QUICK_START=1          # 1 = เปิด topic+พิมพ์ -> Claude+YOLO ทันที (ต้องแพตช์ ccgram-tune.py)
